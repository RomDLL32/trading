# Alpaca paper trading credentials
# Create a paper account and generate keys at https://app.alpaca.markets/paper/dashboard/overview
APCA_API_KEY_ID=your_paper_key_id_here
APCA_API_SECRET_KEY=your_paper_secret_here

# Always points at the paper endpoint. Do NOT change to live without intent.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Strategy knobs (optional; defaults are set in code)
TRADING_UNIVERSE=SPY,QQQ,AAPL,MSFT,NVDA
TRADING_SMA_FAST=10
TRADING_SMA_SLOW=30
TRADING_TARGET_WEIGHT=0.18
TRADING_MAX_GROSS_EXPOSURE=0.95
